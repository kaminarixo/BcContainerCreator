<Window x:Class="BcContainerCreator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BcContainerCreator.App.ViewModels"
        xmlns:views="clr-namespace:BcContainerCreator.App.Views"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BC Container Creator"
        Height="780" Width="1180"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource Surface}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="3" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Brand-Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBg}">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Brand-Logo. Source wird im Code-Behind gesetzt; fehlt die
                     Datei, bleibt das Image leer ohne XAML-Parse-Fehler. -->
                <Image x:Name="LogoImage"
                       Grid.Column="0"
                       Width="42" Height="42"
                       VerticalAlignment="Center"
                       Margin="0,0,14,0"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="BC Container Creator"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Business Central Docker-Container per GUI verwalten"
                               Foreground="#9C9C9C"
                               FontSize="11"
                               Margin="0,2,0,0" />
                </StackPanel>

                <!-- Status-Pill rechts: zeigt ob die App als Admin oder Standard-User läuft -->
                <Border Grid.Column="2"
                        VerticalAlignment="Center"
                        Padding="12,6"
                        CornerRadius="14"
                        Background="#262626">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ContextDot"
                                 Width="9" Height="9"
                                 Fill="{StaticResource BrandOrange}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,8,0" />
                        <TextBlock x:Name="ContextLabel"
                                   Text="Standard-User"
                                   Foreground="#EAEAEA"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Brand-Akzent-Streifen unter dem Header -->
        <Rectangle Grid.Row="1" Fill="{StaticResource BrandGradient}" />

        <!-- TabControl: dunkle Header-Leiste, heller Content-Bereich -->
        <TabControl Grid.Row="2"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    Background="{StaticResource HeaderBg}"
                    BorderThickness="0"
                    Padding="0">
            <TabItem Header="Diagnose">
                <Border Background="{StaticResource Surface}">
                    <views:DiagnosticsView DataContext="{Binding Diagnostics}" />
                </Border>
            </TabItem>
            <TabItem Header="Container erstellen">
                <Border Background="{StaticResource Surface}">
                    <views:CreateContainerView DataContext="{Binding CreateContainer}" />
                </Border>
            </TabItem>
            <TabItem Header="Container verwalten">
                <Border Background="{StaticResource Surface}">
                    <views:ManageContainersView DataContext="{Binding ManageContainers}" />
                </Border>
            </TabItem>
            <TabItem Header="Log">
                <Border Background="{StaticResource Surface}">
                    <views:LogView DataContext="{Binding Log}" />
                </Border>
            </TabItem>
            <TabItem Header="Einstellungen">
                <Border Background="{StaticResource Surface}">
                    <views:SettingsView DataContext="{Binding Settings}" />
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
