<Window x:Class="BcContainerCreator.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BcContainerCreator.App.ViewModels"
        xmlns:views="clr-namespace:BcContainerCreator.App.Views"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BC Container Creator"
        Height="860" Width="1320"
        MinHeight="640" MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource Bg}">

    <!-- Windows-Taskbar-Fortschritt während einer Container-Erstellung:
         Marquee bis zur ersten erkannten Stage, danach echter Fortschritt. -->
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo ProgressState="{Binding CreateContainer.TaskbarProgressState}"
                         ProgressValue="{Binding CreateContainer.TaskbarProgressValue}" />
    </Window.TaskbarItemInfo>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ============================================
             Sidebar
             ============================================ -->
        <Border Grid.Column="0"
                Background="{StaticResource BgSidebar}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand-Block -->
                <Border Grid.Row="0"
                        Padding="20,18,20,16"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="34" Height="34"
                                CornerRadius="8"
                                Background="{StaticResource BgElevated}"
                                Margin="0,0,10,0">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.06" BlurRadius="3" ShadowDepth="1" />
                            </Border.Effect>
                            <Image x:Name="LogoImage"
                                   Width="28" Height="28"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="BC Container Creator"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Text}" />
                            <TextBlock x:Name="VersionLabel"
                                       Text="v1.0.0"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiary}"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <TextBlock Text="WERKZEUGE" Style="{StaticResource SectionLabel}" />

                    <RadioButton GroupName="MainNav"
                                 Style="{StaticResource NavItem}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEquals}, ConverterParameter=0, Mode=TwoWay}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="16" Height="16"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="1.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M 11 2 L 11 4 M 5 2 L 5 4 M 5 3 L 4 3 A 2 2 0 0 0 2 5 L 2 9 A 6 6 0 0 0 14 9 L 14 5 A 2 2 0 0 0 12 3 L 11 3 M 8 15 A 6 6 0 0 0 20 15 L 20 12" />
                            <TextBlock Grid.Column="1"
                                       Text="Diagnose"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="2"
                                    Style="{StaticResource Badge}"
                                    Background="{StaticResource WarningSoft}"
                                    BorderBrush="Transparent"
                                    Visibility="{Binding Diagnostics.Checks.Count, Converter={StaticResource CountToVis}}">
                                <TextBlock Text="{Binding Diagnostics.OkCountSummary}"
                                           Foreground="{StaticResource Warning}"
                                           Style="{StaticResource BadgeText}" />
                            </Border>
                        </Grid>
                    </RadioButton>

                    <RadioButton GroupName="MainNav"
                                 Style="{StaticResource NavItem}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEquals}, ConverterParameter=1, Mode=TwoWay}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="16" Height="16"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="1.8"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 12 5 L 12 19 M 5 12 L 19 12" />
                            <TextBlock Grid.Column="1" Text="Container erstellen" Margin="10,0,0,0" VerticalAlignment="Center" />
                            <!-- Busy-Badge: sichtbar solange eine Erstellung läuft — pulsierender
                                 Punkt plus Fortschritt, damit der Run auch von anderen Tabs aus
                                 sichtbar bleibt. -->
                            <Border Grid.Column="2"
                                    Style="{StaticResource Badge}"
                                    Background="{StaticResource InfoSoft}"
                                    BorderBrush="Transparent"
                                    Visibility="{Binding CreateContainer.IsRunning, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6"
                                             Fill="{StaticResource Info}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,5,0">
                                        <!-- Puls startet mit IsRunning und stoppt sauber am Run-Ende —
                                             ein Loaded-EventTrigger würde die Animation dauerhaft
                                             (auch unsichtbar) weiterlaufen lassen. -->
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CreateContainer.IsRunning}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="BusyPulse">
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="1.0" To="0.25"
                                                                                     Duration="0:0:0.8"
                                                                                     AutoReverse="True"
                                                                                     RepeatBehavior="Forever" />
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="BusyPulse" />
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Foreground="{StaticResource Info}">
                                        <!-- Text via Style-Setter statt lokal, damit der Trigger
                                             (Marquee-Phase → "läuft" statt irreführendem "0 %")
                                             ihn überschreiben kann. -->
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource BadgeText}">
                                                <Setter Property="Text" Value="{Binding CreateContainer.CreateProgressPercent, StringFormat={}{0} %}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CreateContainer.IsCreateProgressIndeterminate}" Value="True">
                                                        <Setter Property="Text" Value="läuft" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </RadioButton>

                    <RadioButton GroupName="MainNav"
                                 Style="{StaticResource NavItem}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEquals}, ConverterParameter=2, Mode=TwoWay}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Width="16" Height="16"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="1.6"
                                  StrokeLineJoin="Round"
                                  Data="M 22 7.7 L 22 14.3 L 12 20 L 2 14.3 L 2 7.7 L 12 2 Z M 12 12 L 12 20 M 2 7.7 L 12 12 L 22 7.7" />
                            <TextBlock Grid.Column="1"
                                       Text="Container"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center" />
                            <Border Grid.Column="2"
                                    Style="{StaticResource Badge}"
                                    Visibility="{Binding ManageContainers.Containers.Count, Converter={StaticResource CountToVis}}">
                                <TextBlock Text="{Binding ManageContainers.Containers.Count}"
                                           Style="{StaticResource BadgeText}" />
                            </Border>
                        </Grid>
                    </RadioButton>

                    <RadioButton GroupName="MainNav"
                                 Style="{StaticResource NavItem}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEquals}, ConverterParameter=3, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="16" Height="16"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="1.6"
                                  StrokeLineJoin="Round"
                                  Data="M 3 3 L 21 3 L 21 21 L 3 21 Z M 7 11 L 9 9 L 7 7 M 11 13 L 15 13" />
                            <TextBlock Text="Logs" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <RadioButton GroupName="MainNav"
                                 Style="{StaticResource NavItem}"
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource IntEquals}, ConverterParameter=4, Mode=TwoWay}">
                        <StackPanel Orientation="Horizontal">
                            <Path Width="16" Height="16"
                                  Stretch="Uniform"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                  StrokeThickness="1.6"
                                  StrokeLineJoin="Round"
                                  Data="M 12 9 A 3 3 0 1 0 12 15 A 3 3 0 1 0 12 9 M 19.4 15 A 1.6 1.6 0 0 0 19.7 16.7 L 19.7 16.8 A 2 2 0 1 1 16.9 19.6 L 16.8 19.6 A 1.6 1.6 0 0 0 15.1 19.9 A 1.6 1.6 0 0 0 14 21.4 L 14 21.5 A 2 2 0 1 1 10 21.5 L 10 21.4 A 1.6 1.6 0 0 0 8.9 19.9 A 1.6 1.6 0 0 0 7.2 19.6 L 7.1 19.6 A 2 2 0 1 1 4.3 16.8 L 4.3 16.7 A 1.6 1.6 0 0 0 4.6 15 A 1.6 1.6 0 0 0 3.1 13.9 L 3 13.9 A 2 2 0 1 1 3 9.9 L 3.1 9.9 A 1.6 1.6 0 0 0 4.6 8.8 A 1.6 1.6 0 0 0 4.3 7.1 L 4.3 7 A 2 2 0 1 1 7.1 4.2 L 7.2 4.2 A 1.6 1.6 0 0 0 8.9 3.9 A 1.6 1.6 0 0 0 10 2.4 L 10 2.3 A 2 2 0 1 1 14 2.3 L 14 2.4 A 1.6 1.6 0 0 0 15.1 3.9 A 1.6 1.6 0 0 0 16.8 4.2 L 16.9 4.2 A 2 2 0 1 1 19.7 7 L 19.7 7.1 A 1.6 1.6 0 0 0 19.4 8.8 A 1.6 1.6 0 0 0 20.9 9.9 L 21 9.9 A 2 2 0 1 1 21 13.9 L 20.9 13.9 A 1.6 1.6 0 0 0 19.4 15 Z" />
                            <TextBlock Text="Einstellungen" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Sidebar-Foot: User-Pill -->
                <Border Grid.Row="2"
                        Padding="20,12,20,16"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Border Style="{StaticResource Badge}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6"
                                         Fill="{StaticResource Success}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,6,0" />
                                <TextBlock x:Name="UserNameLabel"
                                           Text="user"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondary}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ============================================
             Main area
             ============================================ -->
        <Grid Grid.Column="1" Background="{StaticResource Bg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="38" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Title bar (slim) -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgSidebar}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="14,0">
                    <TextBlock x:Name="TitleText"
                               Text="BC Container Creator"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextTertiary}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Page content -->
            <Grid Grid.Row="1">
                <ContentControl Content="{Binding}">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <views:DiagnosticsView DataContext="{Binding Diagnostics}" />
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <views:CreateContainerView DataContext="{Binding CreateContainer}" />
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <views:ManageContainersView DataContext="{Binding ManageContainers}" />
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <views:LogView DataContext="{Binding Log}" />
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTabIndex}" Value="4">
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <views:SettingsView DataContext="{Binding Settings}" />
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Grid>
        </Grid>
    </Grid>
</Window>
