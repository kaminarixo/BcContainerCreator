<Window x:Class="BcContainerCreator.App.Views.ContainerInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BcContainerCreator.App.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:ContainerCredentialsViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Container-Zugangsdaten"
        Height="540" Width="640"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Surface}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4">
                <Run Text="Container: " />
                <Run Text="{Binding ContainerName, Mode=OneWay}" Foreground="{StaticResource BrandRed}" />
            </TextBlock>
            <TextBlock Text="{Binding CreatedAtDisplay, StringFormat=Erstellt am: {0}}"
                       FontSize="12"
                       Foreground="{StaticResource TextMuted}"
                       Margin="0,0,0,16"
                       Visibility="{Binding HasMetadata, Converter={StaticResource BoolToVis}}" />

            <!-- Hinweis wenn keine Metadaten vorhanden -->
            <Border Style="{StaticResource Card}"
                    Background="#FFF6E5"
                    BorderBrush="{StaticResource BrandOrange}"
                    Margin="0,0,0,12"
                    Visibility="{Binding HasMetadata, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                <TextBlock Text="{Binding MissingMessage}"
                           TextWrapping="Wrap" />
            </Border>

            <!-- Web-Client -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Web-Client URL"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,6" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding WebClientUrl, Mode=OneWay}" IsReadOnly="True" FontFamily="{StaticResource MonoFont}" />
                        <Button Grid.Column="1" Content="Kopieren" Margin="6,0,0,0" Command="{Binding CopyUrlCommand}" />
                        <Button Grid.Column="2" Content="Öffnen" Style="{StaticResource PrimaryButton}" Margin="6,0,0,0" Command="{Binding OpenUrlCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Zugangsdaten — nur wenn Metadaten vorhanden -->
            <StackPanel Visibility="{Binding HasMetadata, Converter={StaticResource BoolToVis}}">
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Anmelde-Typ"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="{Binding AuthType}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Benutzername"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding Username, Mode=OneWay}" IsReadOnly="True" FontFamily="{StaticResource MonoFont}" />
                            <Button Grid.Column="1" Content="Kopieren" Margin="6,0,0,0" Command="{Binding CopyUsernameCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- DPAPI-Konto-Mismatch: Passwort existiert, gehört aber einem
                     anderen Windows-Konto — erklären statt kommentarlos ausblenden. -->
                <Border Style="{StaticResource Card}"
                        Background="#FFF6E5"
                        BorderBrush="{StaticResource BrandOrange}"
                        Margin="0,0,0,12"
                        Visibility="{Binding IsPasswordLocked, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding PasswordLockedMessage}"
                               TextWrapping="Wrap" />
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,12"
                        Visibility="{Binding HasPassword, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Passwort"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}" />
                            <CheckBox Grid.Column="1" Content="Anzeigen" IsChecked="{Binding ShowPassword}" FontSize="12" />
                        </Grid>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding PasswordDisplay, Mode=OneWay}" IsReadOnly="True" FontFamily="{StaticResource MonoFont}" />
                            <Button Grid.Column="1" Content="Kopieren" Margin="6,0,0,0" Command="{Binding CopyPasswordCommand}" />
                        </Grid>
                        <TextBlock Text="{Binding ClipboardHint}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ClipboardHint}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Artifact-Typ" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ArtifactType}" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Country" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Country}" Margin="0,6,0,0" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Version" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding VersionSelector}" Margin="0,6,0,0" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Erstellt von" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding CreatedBy}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CreatedBy}" Value="">
                                            <Setter Property="Text" Value="unbekannt (ältere App-Version)" />
                                            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Sicherheits-Hinweis: gespeicherte Passwörter sind an das
                     Windows-Konto gebunden (DPAPI CurrentUser). -->
                <TextBlock Text="Gespeicherte Passwörter sind verschlüsselt an das Windows-Konto gebunden, das den Container erstellt hat — andere Benutzer dieses Rechners können sie nicht auslesen."
                           FontSize="11"
                           Foreground="{StaticResource TextMuted}"
                           TextWrapping="Wrap"
                           Margin="4,0,4,0" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
