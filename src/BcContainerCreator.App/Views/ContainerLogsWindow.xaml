<Window x:Class="BcContainerCreator.App.Views.ContainerLogsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BcContainerCreator.App.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:ContainerLogsViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Container-Logs"
        Height="640" Width="980"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Surface}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10">
            <Run Text="Logs: " />
            <Run Text="{Binding ContainerName, Mode=OneWay}" Foreground="{StaticResource BrandRed}" />
        </TextBlock>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Aktualisieren"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,12,0"
                    Command="{Binding LoadCommand}" />
            <Label Content="Letzte Zeilen:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox ItemsSource="{Binding TailOptions}"
                      SelectedItem="{Binding Tail}"
                      MinWidth="100"
                      VerticalAlignment="Center" />
            <TextBlock Text="{Binding StatusText}"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextMuted}" />
        </StackPanel>

        <Border Grid.Row="2"
                Background="#101010"
                BorderBrush="{StaticResource SurfaceBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource CardCorner}">
            <TextBox x:Name="LogText"
                     Text="{Binding Logs, Mode=OneWay}"
                     IsReadOnly="True"
                     Background="Transparent"
                     Foreground="#DDDDDD"
                     BorderThickness="0"
                     Padding="12"
                     FontFamily="{StaticResource MonoFont}"
                     FontSize="12"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap" />
        </Border>

        <ProgressBar Grid.Row="3"
                     Height="4"
                     Margin="0,8,0,0"
                     IsIndeterminate="{Binding IsLoading}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
    </Grid>
</Window>
