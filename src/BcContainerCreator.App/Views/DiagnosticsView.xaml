<UserControl x:Class="BcContainerCreator.App.Views.DiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BcContainerCreator.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:DiagnosticsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="Alle prüfen"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,8,0"
                    Command="{Binding RunAllCommand}" />
            <Button Content="Alle Fixes anwenden"
                    Command="{Binding FixAllCommand}" />
            <TextBlock Text="{Binding StatusText}"
                       Margin="16,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextMuted}" />
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1">
            <ListView ItemsSource="{Binding Checks}"
                      BorderThickness="0"
                      Background="Transparent">
                <ListView.View>
                    <GridView>
                        <GridView.Columns>
                            <GridViewColumn Header="" Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="22" Height="22"
                                                CornerRadius="11"
                                                HorizontalAlignment="Center"
                                                Background="{Binding Status, Converter={StaticResource StatusToBrush}}">
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToIcon}}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"
                                                       FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Check" Width="240" DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Status" Width="380" DisplayMemberBinding="{Binding Message}" />
                            <GridViewColumn Header="" Width="160">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="🔒"
                                                       FontSize="13"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextMuted}"
                                                       ToolTip="Erfordert UAC. Bei Standard-Usern: lokalen Admin-Account eingeben (z. B. .\admin)."
                                                       Visibility="{Binding RequiresAdminForFix, Converter={StaticResource BoolToVis}}" />
                                            <Button Content="Fix"
                                                    Padding="14,4"
                                                    MinWidth="74"
                                                    Visibility="{Binding IsFixable, Converter={StaticResource BoolToVis}}"
                                                    IsEnabled="{Binding IsFixing, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                                    Command="{Binding DataContext.FixCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView.Columns>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <ProgressBar Grid.Row="2"
                     Height="4"
                     Margin="0,8,0,0"
                     IsIndeterminate="{Binding IsRunning}"
                     Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
    </Grid>
</UserControl>
