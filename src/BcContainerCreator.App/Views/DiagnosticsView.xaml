<UserControl x:Class="BcContainerCreator.App.Views.DiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BcContainerCreator.App.ViewModels"
             xmlns:models="clr-namespace:BcContainerCreator.Core.Models;assembly=BcContainerCreator.Core"
             d:DataContext="{d:DesignInstance Type=vm:DiagnosticsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="36,28,36,40" MaxWidth="1080" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Page-Head -->
            <Grid Grid.Row="0" Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Crumb}">
                        <Run Text="Werkzeuge" />
                        <Run Text="  /  " Foreground="{StaticResource TextTertiary}" />
                        <Run Text="Diagnose" />
                    </TextBlock>
                    <TextBlock Text="Voraussetzungen" Style="{StaticResource PageTitle}" />
                    <TextBlock Style="{StaticResource PageSubtitle}" MaxWidth="640" HorizontalAlignment="Left">
                        <Run Text="12 Checks. Wenn alles grün ist, läuft" />
                        <Run Text="New-BcContainer" FontFamily="{StaticResource MonoFont}" />
                        <Run Text="reproduzierbar durch." />
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Erneut prüfen"
                        Margin="0,0,8,0"
                        Command="{Binding RunAllCommand}" />
                <Button Grid.Column="2"
                        Content="Alle Probleme beheben"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding FixAllCommand}" />
            </Grid>

            <!-- Summary-Card -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,18">
                <Grid Margin="20,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding OkCount}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Text}" />
                            <TextBlock Text="{Binding Checks.Count, StringFormat=' / {0}'}"
                                       FontSize="18"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextTertiary}"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="Checks bestanden"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Bottom"
                                       Margin="14,0,0,7" />
                        </StackPanel>
                        <ProgressBar Margin="0,12,0,0"
                                     Height="6"
                                     Maximum="{Binding Checks.Count}"
                                     Value="{Binding OkCount, Mode=OneWay}"
                                     Foreground="{StaticResource Success}"
                                     Background="{StaticResource BgSubtle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="1" Background="{StaticResource Border}" Margin="0,4" />
                        <StackPanel Margin="20,0,0,0" MinWidth="80">
                            <TextBlock Text="OK" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextTertiary}" />
                            <TextBlock Text="{Binding OkCount}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Success}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="20,0,0,0" MinWidth="80">
                            <TextBlock Text="WARNUNG" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextTertiary}" />
                            <TextBlock Text="{Binding WarnCount}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Warning}" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Margin="20,0,0,0" MinWidth="80">
                            <TextBlock Text="FEHLER" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextTertiary}" />
                            <TextBlock Text="{Binding FailCount}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Danger}" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Check-Liste -->
            <ItemsControl Grid.Row="2" ItemsSource="{Binding Checks}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CheckResultViewModel}">
                        <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                            <Grid Margin="18,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Status-Icon -->
                                <Border Grid.Column="0"
                                        Width="28" Height="28"
                                        CornerRadius="8"
                                        Background="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                        Opacity="0.16"
                                        VerticalAlignment="Center" />
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Status, Converter={StaticResource StatusToIcon}}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding Status, Converter={StaticResource StatusToBrush}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />

                                <!-- Name + Message -->
                                <StackPanel Grid.Column="1" Margin="14,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Foreground="{StaticResource Text}" />
                                    <TextBlock Text="{Binding Message}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextTertiary}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="🔒"
                                               FontSize="12"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextTertiary}"
                                               ToolTip="Erfordert UAC. Bei Standard-Usern: lokalen Admin-Account eingeben (z. B. .\admin)."
                                               Visibility="{Binding RequiresAdminForFix, Converter={StaticResource BoolToVis}}" />
                                    <Button Content="Beheben"
                                            Style="{StaticResource SmallPrimaryButton}"
                                            MinWidth="78"
                                            Visibility="{Binding IsFixable, Converter={StaticResource BoolToVis}}"
                                            IsEnabled="{Binding IsFixing, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                            Command="{Binding DataContext.FixCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Status-Text + Running-Indicator (verstecktes Bottom) -->
            <ProgressBar Grid.Row="2"
                         Height="2"
                         VerticalAlignment="Top"
                         Margin="0,-2,0,0"
                         IsIndeterminate="True"
                         Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                         Background="Transparent" />
        </Grid>
    </ScrollViewer>
</UserControl>
