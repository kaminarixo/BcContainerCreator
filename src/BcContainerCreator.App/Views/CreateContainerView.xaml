<UserControl x:Class="BcContainerCreator.App.Views.CreateContainerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BcContainerCreator.App.ViewModels"
             xmlns:svc="clr-namespace:BcContainerCreator.App.Services"
             xmlns:models="clr-namespace:BcContainerCreator.Core.Models;assembly=BcContainerCreator.Core"
             d:DataContext="{d:DesignInstance Type=vm:CreateContainerViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Segment-Button: ToggleButton-Look der gruppierten Auswahl (Sandbox/OnPrem etc.) -->
        <Style x:Key="SegmentRadio" TargetType="{x:Type RadioButton}">
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgElevated}" />
                                <Setter Property="Foreground" Value="{StaticResource Text}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Text}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentGroup" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource BgSubtle}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
    </UserControl.Resources>

    <!-- Outer Grid füllt UserControl-Höhe (kein outer ScrollViewer — sonst wächst
         die Console im rechten Card unbegrenzt mit dem Output statt zu scrollen). -->
    <Grid Margin="36,28,36,28" MaxWidth="1320" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

            <!-- Page-Head -->
            <Grid Grid.Row="0" Margin="0,0,0,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Style="{StaticResource Crumb}">
                        <Run Text="Werkzeuge" />
                        <Run Text="  /  " Foreground="{StaticResource TextTertiary}" />
                        <Run Text="Container" />
                        <Run Text="  /  " Foreground="{StaticResource TextTertiary}" />
                        <Run Text="Erstellen" />
                    </TextBlock>
                    <TextBlock Text="Neuen Container erstellen" Style="{StaticResource PageTitle}" />
                    <TextBlock Style="{StaticResource PageSubtitle}" MaxWidth="720" HorizontalAlignment="Left">
                        <Run Text="Versions-Auswahl, Auth, optionale Features. Live-Output rechts — der Aufruf läuft als externer" />
                        <Run Text="powershell.exe" FontFamily="{StaticResource MonoFont}" />
                        <Run Text="-Subprozess." />
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- Two-column area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: Formular — eigener ScrollViewer, damit lange Form
                     unabhängig vom rechten Live-Output-Card scrollt. -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,0,8,8">
                    <StackPanel IsEnabled="{Binding IsCreateFormEnabled}">

                    <!-- Card: Container -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Padding="20,14"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="Container" Style="{StaticResource CardTitle}" />
                                    <TextBlock Text="Identität &amp; BC-Version" Style="{StaticResource CardSub}" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1" Margin="20,16,20,18">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Containername + Country -->
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6">
                                        <Run Text="Container-Name" />
                                        <Run Text="*" Foreground="{StaticResource Brand}" />
                                    </TextBlock>
                                    <TextBox Style="{StaticResource MonoTextBox}"
                                             Text="{Binding ContainerName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6">
                                        <Run Text="Country" />
                                        <Run Text="*" Foreground="{StaticResource Brand}" />
                                    </TextBlock>
                                    <ComboBox ItemsSource="{Binding Countries}"
                                              SelectedItem="{Binding SelectedCountry}"
                                              IsEditable="True" />
                                </StackPanel>

                                <!-- Version + Artifact-Typ -->
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}">
                                            <Run Text="BC-Version" />
                                            <Run Text="*" Foreground="{StaticResource Brand}" />
                                        </TextBlock>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource SmallGhostButton}"
                                                Content="Aktualisieren"
                                                Command="{Binding ReloadVersionsCommand}"
                                                IsEnabled="{Binding IsLoadingVersions, Converter={StaticResource InverseBool}}" />
                                    </Grid>
                                    <ComboBox ItemsSource="{Binding AvailableVersions}"
                                              SelectedItem="{Binding SelectedVersion}"
                                              DisplayMemberPath="Display" />
                                    <StackPanel Orientation="Horizontal" Margin="2,4,0,0">
                                        <TextBlock Text="Lade Versionen…"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextTertiary}"
                                                   Visibility="{Binding IsLoadingVersions, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock FontSize="11"
                                                   Foreground="{StaticResource TextTertiary}"
                                                   Visibility="{Binding IsLoadingVersions, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                            <Run Text="Aufgelöst:" />
                                            <Run Text="{Binding ResolvedBuild, FallbackValue=unbekannt, TargetNullValue=unbekannt, Mode=OneWay}"
                                                 FontWeight="SemiBold"
                                                 FontFamily="{StaticResource MonoFont}" />
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="Artifact-Typ"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{StaticResource TextSecondary}"
                                               Margin="0,0,0,6" />
                                    <Border Style="{StaticResource SegmentGroup}">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton GroupName="ArtifactTypeSeg"
                                                         Style="{StaticResource SegmentRadio}"
                                                         Content="Sandbox"
                                                         IsChecked="{Binding SelectedArtifactType, Converter={StaticResource Equals}, ConverterParameter={x:Static models:ArtifactType.Sandbox}, Mode=TwoWay}" />
                                            <RadioButton GroupName="ArtifactTypeSeg"
                                                         Style="{StaticResource SegmentRadio}"
                                                         Content="OnPrem"
                                                         IsChecked="{Binding SelectedArtifactType, Converter={StaticResource Equals}, ConverterParameter={x:Static models:ArtifactType.OnPrem}, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Card: Authentifizierung -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Padding="20,14"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Text="Authentifizierung" Style="{StaticResource CardTitle}" />
                                    <TextBlock Text="Zugangsdaten — Passwort als SecureString" Style="{StaticResource CardSub}" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="1" Margin="20,16,20,18">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Auth-Typ + Lizenz -->
                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="Auth-Typ" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6" />
                                    <Border Style="{StaticResource SegmentGroup}">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton GroupName="AuthTypeSeg"
                                                         Style="{StaticResource SegmentRadio}"
                                                         Content="NavUserPassword"
                                                         IsChecked="{Binding SelectedAuthType, Converter={StaticResource Equals}, ConverterParameter={x:Static models:AuthType.NavUserPassword}, Mode=TwoWay}" />
                                            <RadioButton GroupName="AuthTypeSeg"
                                                         Style="{StaticResource SegmentRadio}"
                                                         Content="Windows"
                                                         IsChecked="{Binding SelectedAuthType, Converter={StaticResource Equals}, ConverterParameter={x:Static models:AuthType.Windows}, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="Lizenz-Datei (optional)" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Style="{StaticResource MonoTextBox}"
                                                 Text="{Binding LicenseFilePath, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="True" />
                                        <Button Grid.Column="1"
                                                Content="…"
                                                MinWidth="40"
                                                Margin="6,0,0,0"
                                                Command="{Binding PickLicenseFileCommand}" />
                                    </Grid>
                                </StackPanel>

                                <!-- Username + Passwort -->
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="Username" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6" />
                                    <TextBox Style="{StaticResource MonoTextBox}"
                                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Passwort" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" />
                                        <CheckBox Grid.Column="1"
                                                  Content="Anzeigen"
                                                  FontSize="11"
                                                  Foreground="{StaticResource TextTertiary}"
                                                  IsChecked="{Binding ShowPassword}" />
                                    </Grid>
                                    <Grid>
                                        <PasswordBox svc:PasswordBoxAssistant.BindPassword="True"
                                                     svc:PasswordBoxAssistant.PlainPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                                        <TextBox Style="{StaticResource MonoTextBox}"
                                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVis}}" />
                                    </Grid>
                                </StackPanel>

                                <!-- EULA + AL -->
                                <StackPanel Grid.Row="4" Grid.Column="0" Orientation="Horizontal">
                                    <CheckBox Content="EULA akzeptieren" IsChecked="{Binding AcceptEula}" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal">
                                    <CheckBox Content="AL-Tooling einbinden" IsChecked="{Binding IncludeAL}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Card: Erweiterte Optionen (Expander-look) -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                        <Expander IsExpanded="{Binding ShowAdvanced}" Background="Transparent" BorderThickness="0">
                            <Expander.Header>
                                <StackPanel Margin="0,2">
                                    <TextBlock Text="Erweiterte Optionen" Style="{StaticResource CardTitle}" />
                                    <TextBlock Text="Multitenant, Memory, Isolation, TestToolkit" Style="{StaticResource CardSub}" Margin="0,2,0,0" />
                                </StackPanel>
                            </Expander.Header>
                            <Grid Margin="0,12,0,4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox Grid.Row="0" Grid.Column="0"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Multitenant}">
                                    <StackPanel>
                                        <TextBlock Text="MultiTenant" />
                                        <TextBlock Text="Pro Tenant separate DB" FontSize="11" Foreground="{StaticResource TextTertiary}" />
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox Grid.Row="0" Grid.Column="2"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding IncludeTestToolkit}">
                                    <StackPanel>
                                        <TextBlock Text="TestToolkit installieren" />
                                        <TextBlock Text="Performance- + Test-Toolkit" FontSize="11" Foreground="{StaticResource TextTertiary}" />
                                    </StackPanel>
                                </CheckBox>

                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="Memory-Limit" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6" />
                                    <TextBox Style="{StaticResource MonoTextBox}"
                                             Text="{Binding MemoryLimit, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="z. B. 8G, 16G — leer = unbegrenzt" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="2">
                                    <TextBlock Text="Isolation-Mode" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6" />
                                    <ComboBox ItemsSource="{Binding IsolationModes}"
                                              SelectedItem="{Binding SelectedIsolation}" />
                                </StackPanel>
                            </Grid>
                        </Expander>
                    </Border>

                    <!-- Action-Row -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                        <Button Content="Container erstellen"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="180"
                                Command="{Binding CreateCommand}" />
                    </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- RIGHT: Live-Output-Card — füllt verfügbare Höhe; Console intern scrollbar -->
                <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Card-Head -->
                        <Border Grid.Row="0"
                                Padding="20,14"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Live-Output" Style="{StaticResource CardTitle}" />
                                    <TextBlock Style="{StaticResource CardSub}" Margin="0,2,0,0">
                                        <Run Text="{Binding ContainerName, FallbackValue=bcdev, Mode=OneWay}" FontFamily="{StaticResource MonoFont}" />
                                        <Run Text=" — " />
                                        <Run Text="{Binding CreateProgressText, FallbackValue=Bereit, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Style="{StaticResource Badge}"
                                        Background="{StaticResource BrandSoft}"
                                        BorderBrush="Transparent"
                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource Brand}" Margin="0,0,5,0" VerticalAlignment="Center" />
                                        <TextBlock Text="läuft" Foreground="{StaticResource Brand}" FontSize="11" FontWeight="Medium" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Progress-Sektion -->
                        <Border Grid.Row="1"
                                Padding="20,14"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Fortschritt"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="{StaticResource TextSecondary}" />
                                    <TextBlock Grid.Column="1"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brand}">
                                        <Run Text="{Binding CreateProgressPercent, Mode=OneWay}" />
                                        <Run Text="%" />
                                    </TextBlock>
                                </Grid>

                                <ProgressBar Margin="0,8,0,0"
                                             Height="6"
                                             Minimum="0" Maximum="100"
                                             Value="{Binding CreateProgressPercent, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsCreateProgressIndeterminate}"
                                             Foreground="{StaticResource Brand}"
                                             Background="{StaticResource BgSubtle}" />

                                <TextBlock Text="{Binding CreateProgressText}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Console -->
                        <Border Grid.Row="2"
                                Background="{StaticResource BgCode}"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="0,0,0,1"
                                MinHeight="240">
                            <TextBox x:Name="OutputBox"
                                     Style="{StaticResource ConsoleTextBox}"
                                     Text="{Binding Output, Mode=OneWay}"
                                     TextChanged="OutputBox_TextChanged" />
                        </Border>

                        <!-- Card-Foot -->
                        <Border Grid.Row="3"
                                Background="{StaticResource BgSidebar}"
                                CornerRadius="0,0,12,12"
                                Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock Text="Externer powershell.exe-Subprozess"
                                               FontSize="11"
                                               Foreground="{StaticResource TextTertiary}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Style="{StaticResource SmallDangerButton}"
                                        Content="Abbrechen"
                                        Command="{Binding CancelCommand}"
                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
    </Grid>
</UserControl>
