<Application x:Class="BcContainerLauncher.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:BcContainerLauncher.App.Converters">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Value-Converter -->
            <conv:CheckStatusToBrushConverter x:Key="StatusToBrush" />
            <conv:CheckStatusToIconConverter x:Key="StatusToIcon" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:LogLevelToBrushConverter x:Key="LevelToBrush" />

            <!-- Brand-Palette (abgeleitet aus dem Logo) -->
            <Color x:Key="BrandRedColor">#C8302A</Color>
            <Color x:Key="BrandRedDarkColor">#8B1A14</Color>
            <Color x:Key="BrandOrangeColor">#E94E1B</Color>
            <Color x:Key="BrandOrangeLightColor">#F47A4A</Color>
            <Color x:Key="SurfaceColor">#FFFFFF</Color>
            <Color x:Key="SurfaceMutedColor">#F7F7F7</Color>
            <Color x:Key="SurfaceBorderColor">#E1E1E1</Color>
            <Color x:Key="TextColor">#1F1F1F</Color>
            <Color x:Key="TextMutedColor">#666666</Color>
            <Color x:Key="HeaderBgColor">#1A1A1A</Color>

            <SolidColorBrush x:Key="BrandRed" Color="{StaticResource BrandRedColor}" />
            <SolidColorBrush x:Key="BrandRedDark" Color="{StaticResource BrandRedDarkColor}" />
            <SolidColorBrush x:Key="BrandOrange" Color="{StaticResource BrandOrangeColor}" />
            <SolidColorBrush x:Key="Surface" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="SurfaceMuted" Color="{StaticResource SurfaceMutedColor}" />
            <SolidColorBrush x:Key="SurfaceBorder" Color="{StaticResource SurfaceBorderColor}" />
            <SolidColorBrush x:Key="Text" Color="{StaticResource TextColor}" />
            <SolidColorBrush x:Key="TextMuted" Color="{StaticResource TextMutedColor}" />
            <SolidColorBrush x:Key="HeaderBg" Color="{StaticResource HeaderBgColor}" />

            <!-- Brand-Verlauf für Header-Akzente und Primary-Buttons -->
            <LinearGradientBrush x:Key="BrandGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource BrandOrangeColor}" Offset="0" />
                <GradientStop Color="{StaticResource BrandRedColor}" Offset="0.55" />
                <GradientStop Color="{StaticResource BrandRedDarkColor}" Offset="1" />
            </LinearGradientBrush>

            <!-- Backwards-compat Aliase, damit ältere Views weiter laufen -->
            <SolidColorBrush x:Key="PanelBg" Color="{StaticResource SurfaceMutedColor}" />
            <SolidColorBrush x:Key="PanelBorder" Color="{StaticResource SurfaceBorderColor}" />
            <SolidColorBrush x:Key="HeaderFg" Color="{StaticResource TextColor}" />

            <!-- Schriftarten -->
            <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, Courier New</FontFamily>
            <FontFamily x:Key="UiFont">Segoe UI Variable, Segoe UI, Arial</FontFamily>

            <!-- ===== Styles ===== -->

            <!-- Globale Defaults -->
            <Style TargetType="{x:Type Window}">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="Background" Value="{StaticResource Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Text}" />
            </Style>

            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="Foreground" Value="{StaticResource Text}" />
            </Style>

            <Style TargetType="{x:Type Label}">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="Padding" Value="0,4,0,2" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <!-- Eingabefelder -->
            <Style TargetType="{x:Type TextBox}">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{StaticResource Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Text}" />
                <Setter Property="MinHeight" Value="30" />
                <Style.Triggers>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BrandRed}" />
                    </Trigger>
                    <Trigger Property="Validation.HasError" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BrandOrange}" />
                        <Setter Property="ToolTip"
                                Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)/ErrorContent}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type PasswordBox}">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{StaticResource Surface}" />
                <Setter Property="MinHeight" Value="30" />
                <Style.Triggers>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource BrandRed}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type ComboBox}">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Background" Value="{StaticResource Surface}" />
            </Style>

            <Style TargetType="{x:Type CheckBox}">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="Foreground" Value="{StaticResource Text}" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>

            <!-- Default-Button (sekundär) -->
            <Style TargetType="{x:Type Button}">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="Padding" Value="14,7" />
                <Setter Property="Background" Value="{StaticResource Surface}" />
                <Setter Property="Foreground" Value="{StaticResource Text}" />
                <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="MinHeight" Value="30" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceMuted}" />
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BrandRed}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceBorder}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Primary-Button (Brand-Verlauf) — explizit per x:Key referenzieren -->
            <Style x:Key="PrimaryButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="{StaticResource BrandGradient}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.92" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.78" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TabControl im Brand-Stil: dunkler Header mit roter Akzentlinie für aktiven Tab -->
            <Style TargetType="{x:Type TabControl}">
                <Setter Property="Background" Value="{StaticResource Surface}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style TargetType="{x:Type TabItem}">
                <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#BFBFBF" />
                <Setter Property="Padding" Value="22,10" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type TabItem}">
                            <Grid>
                                <Border x:Name="Bd"
                                        Background="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                                <Border x:Name="Indicator"
                                        Height="3"
                                        VerticalAlignment="Bottom"
                                        Background="{StaticResource BrandGradient}"
                                        Visibility="Collapsed" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter TargetName="Indicator" Property="Visibility" Value="Visible" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ListView im Brand-Stil -->
            <Style TargetType="{x:Type ListViewItem}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Padding" Value="6,8" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#FFF1EE" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="{x:Type GridViewColumnHeader}">
                <Setter Property="Background" Value="{StaticResource SurfaceMuted}" />
                <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="BorderBrush" Value="{StaticResource SurfaceBorder}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
