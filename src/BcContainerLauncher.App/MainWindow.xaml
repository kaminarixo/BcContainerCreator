<Window x:Class="BcContainerLauncher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:BcContainerLauncher.App.ViewModels"
        xmlns:views="clr-namespace:BcContainerLauncher.App.Views"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BC Container Launcher"
        Height="720" Width="1100"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Margin="0">
            <TabItem Header="Diagnose">
                <views:DiagnosticsView DataContext="{Binding Diagnostics}" />
            </TabItem>
            <TabItem Header="Container erstellen">
                <views:CreateContainerView DataContext="{Binding CreateContainer}" />
            </TabItem>
            <TabItem Header="Container verwalten">
                <views:PlaceholderView Tag="Container verwalten" />
            </TabItem>
            <TabItem Header="Log">
                <views:LogView DataContext="{Binding Log}" />
            </TabItem>
            <TabItem Header="Einstellungen">
                <views:PlaceholderView Tag="Einstellungen" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
