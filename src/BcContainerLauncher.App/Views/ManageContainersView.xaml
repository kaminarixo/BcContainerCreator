<UserControl x:Class="BcContainerLauncher.App.Views.ManageContainersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BcContainerLauncher.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:ManageContainersViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Aktualisieren"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,12,0"
                        Command="{Binding RefreshCommand}" />
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextMuted}" />
            </StackPanel>
            <CheckBox Grid.Column="2"
                      Content="Auto-Refresh (10s)"
                      VerticalAlignment="Center"
                      IsChecked="{Binding AutoRefreshEnabled}" />
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource Surface}"
                BorderBrush="{StaticResource SurfaceBorder}"
                BorderThickness="1"
                CornerRadius="{StaticResource CardCorner}">
            <ListView ItemsSource="{Binding Containers}"
                      BorderThickness="0"
                      Background="Transparent"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <ListView.View>
                    <GridView>
                        <GridView.Columns>
                            <GridViewColumn Header="" Width="42">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#9E9E9E" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Fill" Value="#2EA04F" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Name" Width="220" DisplayMemberBinding="{Binding Name}" />
                            <GridViewColumn Header="Image" Width="320" DisplayMemberBinding="{Binding Image}" />
                            <GridViewColumn Header="Status" Width="220" DisplayMemberBinding="{Binding Status}" />
                            <GridViewColumn Header="" Width="540">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="Web öffnen"
                                                    Padding="12,4"
                                                    Margin="0,0,6,0"
                                                    MinWidth="100"
                                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                                                    IsEnabled="{Binding WebClientUrl, Converter={StaticResource BoolToVis}}"
                                                    Command="{Binding DataContext.OpenUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{Binding WebClientUrl}" />
                                            <Button Content="Info"
                                                    Padding="12,4"
                                                    Margin="0,0,6,0"
                                                    MinWidth="70"
                                                    ToolTip="Zugangsdaten anzeigen (URL, Benutzer, Passwort)"
                                                    Command="{Binding DataContext.ShowInfoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Logs"
                                                    Padding="12,4"
                                                    Margin="0,0,6,0"
                                                    MinWidth="70"
                                                    Command="{Binding DataContext.ShowLogsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Start"
                                                    Padding="12,4"
                                                    Margin="0,0,6,0"
                                                    MinWidth="80"
                                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                                    Command="{Binding DataContext.StartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Stop"
                                                    Padding="12,4"
                                                    Margin="0,0,6,0"
                                                    MinWidth="80"
                                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                                                    Command="{Binding DataContext.StopCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Löschen"
                                                    Padding="12,4"
                                                    MinWidth="90"
                                                    Foreground="{StaticResource BrandRed}"
                                                    Command="{Binding DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView.Columns>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <ProgressBar Grid.Row="2"
                     Height="4"
                     Margin="0,8,0,0"
                     IsIndeterminate="{Binding IsLoading}"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
    </Grid>
</UserControl>
