<UserControl x:Class="BcContainerLauncher.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BcContainerLauncher.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel MaxWidth="780" HorizontalAlignment="Left">
            <TextBlock Text="Einstellungen &amp; Info"
                       FontSize="18" FontWeight="SemiBold"
                       Margin="0,0,0,16" />

            <!-- Über-Card -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="App-Version"
                               FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AppVersion}"
                               FontFamily="{StaticResource MonoFont}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text=".NET / OS"
                               FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"
                               Margin="0,8,0,0" />
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,8,0,0">
                        <TextBlock Text="{Binding DotNetVersion, StringFormat=.NET {0}}"
                                   FontFamily="{StaticResource MonoFont}" />
                        <TextBlock Text="{Binding OsVersion}"
                                   FontFamily="{StaticResource MonoFont}"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Ausführungs-Kontext -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Ausführungs-Kontext"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,6" />
                    <TextBlock Text="{Binding ContextLabel}" />
                    <TextBlock Text="Admin-pflichtige Operationen (Docker-Modus-Wechsel, Docker-Desktop-Install) starten on demand einen UAC-Prompt — dort den lokalen Admin-Account angeben (z. B. .\admin)."
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <!-- Logging -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Logging"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,6" />
                    <TextBlock Text="Log-Dateien rollieren täglich, 14 Tage Retention."
                               Foreground="{StaticResource TextMuted}"
                               FontSize="12"
                               Margin="0,0,0,8" />
                    <TextBox Text="{Binding LogFolder, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="{StaticResource MonoFont}" />
                    <Button Content="Log-Ordner öffnen"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Command="{Binding OpenLogFolderCommand}" />
                </StackPanel>
            </Border>

            <!-- Über das Projekt -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Über das Projekt"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextMuted}"
                               Margin="0,0,0,6" />
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8">
                        BC Container Creator ist ein internes Tool für die NAV-2017-zu-BC-28-Migration.
                        Standard-User starten die App ohne UAC; benötigte Admin-Aktionen werden auf Wunsch elevated.
                    </TextBlock>
                    <TextBox Text="{Binding GitHubUrlDisplay, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="{StaticResource MonoFont}" />
                    <Button Content="GitHub öffnen"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Command="{Binding OpenGitHubCommand}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
