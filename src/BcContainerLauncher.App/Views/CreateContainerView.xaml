<UserControl x:Class="BcContainerLauncher.App.Views.CreateContainerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BcContainerLauncher.App.ViewModels"
             xmlns:svc="clr-namespace:BcContainerLauncher.App.Services"
             d:DataContext="{d:DesignInstance Type=vm:CreateContainerViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Eingabeformular: wird gesperrt während Erstellung läuft -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                      IsEnabled="{Binding IsRunning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
            <StackPanel>
                <TextBlock Text="Container-Konfiguration" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />

                <Label Content="Containername" />
                <TextBox Text="{Binding ContainerName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <Label Content="Artifact-Typ" Margin="0,8,0,0" />
                <ComboBox ItemsSource="{Binding ArtifactTypes}"
                          SelectedItem="{Binding SelectedArtifactType}" />

                <Label Content="Country" Margin="0,8,0,0" />
                <ComboBox ItemsSource="{Binding Countries}"
                          SelectedItem="{Binding SelectedCountry}"
                          IsEditable="True" />

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Version (BC LTS)" />
                    <Button Grid.Column="1"
                            Content="Aktualisieren"
                            Padding="8,2"
                            FontSize="11"
                            Command="{Binding ReloadVersionsCommand}" />
                </Grid>
                <ComboBox ItemsSource="{Binding AvailableVersions}"
                          SelectedItem="{Binding SelectedVersion}"
                          DisplayMemberPath="Display" />
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Lade Versionen…"
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               Visibility="{Binding IsLoadingVersions, Converter={StaticResource BoolToVis}}" />
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource TextMuted}"
                               Visibility="{Binding IsLoadingVersions, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                        <Run Text="Aufgelöst: " />
                        <Run Text="{Binding ResolvedBuild, FallbackValue=unbekannt, TargetNullValue=unbekannt, Mode=OneWay}"
                             FontWeight="SemiBold" />
                    </TextBlock>
                </StackPanel>

                <Label Content="Auth-Typ" Margin="0,8,0,0" />
                <ComboBox ItemsSource="{Binding AuthTypes}"
                          SelectedItem="{Binding SelectedAuthType}" />

                <Label Content="Username" Margin="0,8,0,0" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Passwort" />
                    <CheckBox Grid.Column="1"
                              Content="Anzeigen"
                              FontSize="11"
                              VerticalAlignment="Center"
                              IsChecked="{Binding ShowPassword}" />
                </Grid>
                <Grid>
                    <PasswordBox svc:PasswordBoxAssistant.BindPassword="True"
                                 svc:PasswordBoxAssistant.PlainPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                    <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                             Visibility="{Binding ShowPassword, Converter={StaticResource BoolToVis}}"
                             FontFamily="{StaticResource MonoFont}" />
                </Grid>

                <Label Content="Lizenz-Datei (optional)" Margin="0,8,0,0" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding LicenseFilePath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                    <Button Grid.Column="1" Content="…" Padding="10,2" Margin="6,0,0,0"
                            Command="{Binding PickLicenseFileCommand}" />
                </Grid>

                <CheckBox Content="EULA akzeptieren" Margin="0,12,0,0"
                          IsChecked="{Binding AcceptEula}" />
                <CheckBox Content="AL-Tooling einbinden (includeAL)" Margin="0,4,0,0"
                          IsChecked="{Binding IncludeAL}" />

                <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                    <Button Content="Container erstellen"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,8,0"
                            Command="{Binding CreateCommand}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Live-Output rechts; Working-Overlay drüber wenn IsRunning -->
        <Grid Grid.Column="2">
            <Border Background="#101010"
                    BorderBrush="{StaticResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCorner}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Live-Output"
                               Foreground="#CCC" Padding="12,6"
                               FontFamily="{StaticResource MonoFont}" />
                    <TextBox Grid.Row="1"
                             Text="{Binding Output, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="#DDDDDD"
                             BorderThickness="0"
                             Padding="12,4,12,12"
                             FontFamily="{StaticResource MonoFont}"
                             FontSize="12"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" />
                </Grid>
            </Border>

            <!-- Working-Overlay: halb-transparent, drehendes Logo, Cancel-Button -->
            <Border Background="#CC101010"
                    CornerRadius="{StaticResource CardCorner}"
                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Assets/logo.png"
                           Width="96" Height="96"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           HorizontalAlignment="Center">
                        <Image.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotation" Angle="0" CenterX="48" CenterY="48" />
                        </Image.RenderTransform>
                        <Image.Triggers>
                            <EventTrigger RoutedEvent="Image.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="SpinnerRotation"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360"
                                                         Duration="0:0:2.5" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Image.Triggers>
                    </Image>
                    <TextBlock Text="Container wird erstellt …"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,18,0,4" />
                    <TextBlock Text="Erster Start lädt das BC-Image (~10–15 GB) — kann mehrere Minuten dauern."
                               Foreground="#BFBFBF"
                               FontSize="12"
                               HorizontalAlignment="Center" />
                    <Button Content="Abbrechen"
                            Margin="0,22,0,0"
                            HorizontalAlignment="Center"
                            MinWidth="140"
                            Command="{Binding CancelCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
