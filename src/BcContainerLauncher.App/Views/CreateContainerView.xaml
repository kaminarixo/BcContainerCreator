<UserControl x:Class="BcContainerLauncher.App.Views.CreateContainerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BcContainerLauncher.App.ViewModels"
             xmlns:svc="clr-namespace:BcContainerLauncher.App.Services"
             d:DataContext="{d:DesignInstance Type=vm:CreateContainerViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Container-Konfiguration" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />

                <Label Content="Containername" />
                <TextBox Text="{Binding ContainerName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <Label Content="Artifact-Typ" Margin="0,8,0,0" />
                <ComboBox ItemsSource="{Binding ArtifactTypes}"
                          SelectedItem="{Binding SelectedArtifactType}" />

                <Label Content="Country" Margin="0,8,0,0" />
                <ComboBox ItemsSource="{Binding Countries}"
                          SelectedItem="{Binding SelectedCountry}"
                          IsEditable="True" />

                <Label Content="Version" Margin="0,8,0,0" />
                <TextBox Text="{Binding Version, UpdateSourceTrigger=PropertyChanged}" />

                <Label Content="Auth-Typ" Margin="0,8,0,0" />
                <ComboBox ItemsSource="{Binding AuthTypes}"
                          SelectedItem="{Binding SelectedAuthType}" />

                <Label Content="Username" Margin="0,8,0,0" />
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <Label Content="Passwort" Margin="0,8,0,0" />
                <PasswordBox svc:PasswordBoxAssistant.BindPassword="True"
                             svc:PasswordBoxAssistant.BoundPassword="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <Label Content="Lizenz-Datei (optional)" Margin="0,8,0,0" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding LicenseFilePath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                    <Button Grid.Column="1" Content="…" Padding="10,2" Margin="6,0,0,0"
                            Command="{Binding PickLicenseFileCommand}" />
                </Grid>

                <CheckBox Content="EULA akzeptieren" Margin="0,12,0,0"
                          IsChecked="{Binding AcceptEula}" />
                <CheckBox Content="AL-Tooling einbinden (includeAL)" Margin="0,4,0,0"
                          IsChecked="{Binding IncludeAL}" />

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Erstellen"
                            Padding="14,6"
                            Margin="0,0,8,0"
                            Command="{Binding CreateCommand}" />
                    <Button Content="Abbrechen"
                            Padding="14,6"
                            Command="{Binding CancelCommand}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="2"
                Background="#101010"
                BorderBrush="{StaticResource PanelBorder}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Live-Output"
                           Foreground="#CCC" Padding="8,4"
                           FontFamily="{StaticResource MonoFont}" />
                <TextBox Grid.Row="1"
                         Text="{Binding Output, Mode=OneWay}"
                         IsReadOnly="True"
                         Background="Transparent"
                         Foreground="#DDDDDD"
                         BorderThickness="0"
                         FontFamily="{StaticResource MonoFont}"
                         FontSize="12"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
